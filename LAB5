#include <iostream>
using namespace std;
double series(int n) {
    if (n == 1)
        return 1.0;
    if (n % 2 == 0)
        return series(n - 1) - 1.0 / n;
    else
        return series(n - 1) + 1.0 / n;
}

int main() {
    int n;
    cout << "Enter n: ";
    cin >> n;

    double result = series(n);
    cout << "S_" << n << " = " << result << endl;

    return 0;
}
