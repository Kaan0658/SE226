
def factorial(x):
    if (x!=0):
        return x * factorial(x-1)
    return 1

def exp_x(x, n):
    step= lambda i, k:(i ** k) / factorial(k)
    result=0
    for k in range(n+1):
        result+=step(x,k)
    return result


